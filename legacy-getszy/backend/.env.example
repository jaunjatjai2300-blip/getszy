# ================================================================
# GETSZY BACKEND - Environment Variables
# ================================================================
# Copy this to .env and fill in real values
# NEVER commit .env to git

# --- Database ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=getszy_db

# --- Security ---
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
CORS_ORIGINS=https://getszy.com,https://www.getszy.com

# --- Seed credentials (only for initial setup, change after first run) ---
SEED_ADMIN_EMAIL=admin@getszy.com
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
SEED_CUSTOMER_EMAIL=customer@getszy.com
SEED_CUSTOMER_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# --- AI Providers (priority order: Groq > OpenRouter > HF > Gemini > Ollama) ---
# Groq (free, fast, 11K req/day)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_DAILY_LIMIT=11000

# OpenRouter (free tier, 92+ models, 200 req/day free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_DAILY_LIMIT=200

# HuggingFace (free inference API)
HF_API_KEY=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# Gemini Studio (free, 1500 req/day)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_DAILY_LIMIT=1200

# Ollama (local models on VPS — unlimited free)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Cost Guard ---
FREE_ONLY=true  # Set to false to allow paid fallback (Emergent)

# --- Legacy AI (compat) ---
EMERGENT_LLM_KEY=
EMERGENT_MODEL=gpt-4o-mini
LLM_PROVIDER=auto  # auto | groq | openrouter | huggingface | gemini | ollama

# --- GitHub Deploy ---
GITHUB_TOKEN=
GITHUB_REPO=jaunjatjai2300-blip/getszy
GITHUB_BRANCH=main
DEPLOY_WEBHOOK_URL=
DEPLOY_WEBHOOK_TOKEN=

# --- Razorpay (subscriptions) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_ELITE=

# --- Domain ---
DOMAIN=getszy.com
PUBLIC_URL=https://getszy.com

# --- Debug ---
ENABLE_DOCS=0  # Set to 1 to enable /api/docs in production (only for development)
LOG_LEVEL=INFO
