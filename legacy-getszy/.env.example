# ================================================================
# GETSZY - Legacy Backend Environment Variables
# ================================================================
# Copy this to .env inside legacy-getszy/ and fill in real values
# NEVER commit .env to git

# --- Backend ---
MONGO_URL=mongodb://mongo:27017
DB_NAME=getszy_db
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
CORS_ORIGINS=https://getszy.com,https://www.getszy.com

# --- Seed credentials (REQUIRED for first run) ---
SEED_ADMIN_EMAIL=admin@getszy.com
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
SEED_CUSTOMER_EMAIL=customer@getszy.com
SEED_CUSTOMER_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# --- AI / LLM ---
FREE_ONLY=true
LLM_PROVIDER=ollama

# Ollama (local, free — your VPS models)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODEL_2=qwen2.5-coder:14b
OLLAMA_MODEL_3=llama3.2:3b

# Groq (free, fast fallback — get key at console.groq.com)
GROQ_API_KEY=

# Gemini (free fallback — get key at aistudio.google.com)
GEMINI_API_KEY=

# OpenRouter (your credits, many models — get key at openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# --- GitHub Deploy ---
GITHUB_TOKEN=
GITHUB_REPO=jaunjatjai2300-blip/getszy
GITHUB_BRANCH=main
DEPLOY_WEBHOOK_URL=
DEPLOY_WEBHOOK_TOKEN=

# --- Razorpay (subscriptions) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_ELITE=

# --- Emergent (paid fallback, disabled by default) ---
EMERGENT_LLM_KEY=
EMERGENT_MODEL=gpt-4o-mini
