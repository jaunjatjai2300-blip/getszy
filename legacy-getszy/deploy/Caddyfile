getszy.com, www.getszy.com, dash.getszy.com {
    encode gzip

    handle /api/* {
        reverse_proxy backend:8001
    }

    handle /hooks/* {
        uri strip_prefix /hooks
        reverse_proxy host.docker.internal:9000
    }

    handle {
        reverse_proxy frontend:80
    }

    log {
        output stdout
        format console
        level INFO
    }
}
