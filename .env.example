# ================================================================
# GETSZY - Root Environment Variables
# ================================================================
# Copy this to .env and fill in real values
# NEVER commit .env to git

# --- Domain ---
DOMAIN=getszy.com
PUBLIC_URL=https://getszy.com

# --- Backend ---
MONGO_URL=mongodb://mongo:27017
DB_NAME=getszy_db
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
CORS_ORIGINS=https://getszy.com,https://www.getszy.com

# --- Seed credentials (only for initial setup) ---
SEED_ADMIN_EMAIL=admin@getszy.com
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
SEED_CUSTOMER_EMAIL=customer@getszy.com
SEED_CUSTOMER_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# --- AI Providers (use your existing API keys) ---
# Groq (free, fast, 11K req/day)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (free tier, 92+ models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# HuggingFace (free inference)
HF_API_KEY=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# Gemini Studio (free, 1500 req/day)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local models on VPS)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Cost Guard ---
FREE_ONLY=true
LLM_PROVIDER=auto

# --- GitHub Deploy ---
GITHUB_TOKEN=
GITHUB_REPO=jaunjatjai2300-blip/getszy
GITHUB_BRANCH=main
DEPLOY_WEBHOOK_URL=
DEPLOY_WEBHOOK_TOKEN=

# --- Razorpay (subscriptions) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_ELITE=

# --- Debug ---
ENABLE_DOCS=0
LOG_LEVEL=INFO
